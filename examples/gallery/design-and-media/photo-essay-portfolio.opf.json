{
  "$schema": "https://openpresentation.org/schema/opf/v1",
  "name": "Photo Essay Portfolio",
  "description": "Photo Essay Portfolio is a fictional OPF example for portfolio teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "photo-essay-portfolio",
  "language": "english-gb",
  "audience": [
    "marketing-team",
    {
      "id": "board",
      "attentionBudgetMinutes": 25,
      "technicalFluency": "medium",
      "decisionPower": "advisory",
      "recommendedNarratives": [
        "persuade"
      ],
      "recommendedTones": [
        "technical"
      ]
    }
  ],
  "purpose": {
    "id": "report",
    "outcome": "Tell a coherent civic story through image-heavy slides",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "technical",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": {
    "id": "persuade",
    "description": "Photo Essay Portfolio uses a compact evidence-to-decision arc for Urban Lens Collective.",
    "beats": [
      {
        "id": "context",
        "name": "Context",
        "slideType": "text",
        "layoutHint": "text-1x"
      },
      {
        "id": "evidence",
        "name": "Evidence",
        "slideType": "chart",
        "layoutHint": "chart-1x"
      },
      {
        "id": "commitment",
        "name": "Commitment",
        "slideType": "list",
        "layoutHint": "list-3x"
      }
    ]
  },
  "design": {
    "theme": "classic",
    "colorScheme": {
      "id": "vibes",
      "primary": "#047857",
      "secondary": "#B45309",
      "accent": "#BE123C",
      "background": "#0B1220",
      "text": "#F8FAFC",
      "custom": {
        "signal": "#0369A1",
        "risk": "#6D28D9"
      }
    },
    "fontScheme": {
      "id": "century-schoolbook",
      "heading": {
        "family": "Aptos Display",
        "weight": 700
      },
      "body": {
        "family": "Aptos",
        "weight": 400
      },
      "code": {
        "family": "Consolas",
        "weight": 400
      }
