  "description": "Compliance Readiness Review is a fictional OPF example for compliance teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "compliance-readiness-review",
  "language": "english-us",
  "audience": [
    "regulators",
    {
      "id": "candidates",
      "attentionBudgetMinutes": 30,
      "technicalFluency": "low",
      "decisionPower": "informational",
