            "Quarter",
            "Current",
            "Baseline"
          ]
        }
      }
    },
    {
      "id": "s4",
      "section": "Options",
      "layout": "table-1x",
      "title": "Decision Options",
      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Compliance",
            "Program lead",
            "On track",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "Watch",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "At risk",
            "Add weekly office hours"
          ]
        ]
      }
    },
    {
