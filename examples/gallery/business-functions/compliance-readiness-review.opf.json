        "educate"
      ],
      "recommendedTones": [
        "technical"
      ]
    }
  ],
  "purpose": {
    "id": "inform",
    "outcome": "Close audit evidence gaps before external assessment",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "technical",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": {
    "id": "educate",
    "description": "Compliance Readiness Review uses a compact evidence-to-decision arc for Tandem BioSystems.",
