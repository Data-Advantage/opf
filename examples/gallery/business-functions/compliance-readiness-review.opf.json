  "slides": [
    {
      "id": "s1",
      "section": "Opening",
      "layout": "title-subtitle",
      "tag": "Compliance",
      "title": "Compliance Readiness Review",
      "subtitle": "Tandem BioSystems Compliance",
      "notes": "Open by naming the decision: Close audit evidence gaps before external assessment."
    },
    {
      "id": "s2",
      "section": "Context",
      "layout": "text-1x",
      "title": "Why This Matters",
      "text": [
        "Tandem BioSystems should focus the next cycle on ",
        {
          "text": "close audit evidence gaps before external assessment",
          "bold": true,
          "color": "#1D4ED8"
        },
        " while making the operating tradeoffs clear to compliance stakeholders."
      ]
    },
    {
      "id": "s3",
      "section": "Evidence",
      "layout": "chart-1x",
      "title": "Signal Trend",
      "type": "chart",
