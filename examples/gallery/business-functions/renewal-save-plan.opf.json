  "speaker": {
    "id": "speaker",
    "name": "Maya Chen",
    "title": "Program Sponsor",
    "organizationId": "evergreen-crm",
    "bio": "Leads customer success planning for Evergreen CRM.",
    "socials": {
      "mastodon": "@evergreen-crm-speaker"
    }
  },
