      },
      "center": {
        "text": "Decision review"
      },
      "right": {
        "slideNumber": true
      }
    },
    "slideImage": {
      "src": "asset:cover-bg",
      "position": "background"
    }
  },
  "slides": [
    {
      "id": "s1",
      "section": "Opening",
      "layout": "title",
      "tag": "Customer success",
      "title": "Renewal Save Plan",
      "subtitle": "Evergreen CRM Customer success",
      "notes": "Open by naming the decision: Recover at-risk renewals with executive sponsorship and value proof."
    },
    {
      "id": "s2",
      "section": "Context",
      "layout": "text-3x",
      "title": "Why This Matters",
      "text": [
        "Evergreen CRM should focus the next cycle on ",
        {
          "text": "recover at-risk renewals with executive sponsorship and value proof",
          "bold": true,
          "color": "#0F172A"
        },
        " while making the operating tradeoffs clear to customer success stakeholders."
      ]
    },
    {
      "id": "s3",
      "section": "Evidence",
      "layout": "chart-3x",
      "title": "Signal Trend",
      "type": "chart",
      "chart": {
        "type": "doughnut",
        "data": {
          "columns": [
            "Quarter",
            "Current",
            "Baseline"
          ],
          "rows": [
            [
              "Q1",
              13,
              10
            ],
            [
              "Q2",
              17,
              12
            ],
            [
              "Q3",
              20,
              14
            ],
            [
              "Q4",
              24,
              16
            ]
          ]
        }
      }
    },
    {
      "id": "s4",
      "section": "Options",
      "layout": "table-1x",
      "title": "Decision Options",
      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Customer success",
            "Program lead",
            "At risk",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "On track",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "Watch",
            "Add weekly office hours"
          ]
        ]
      }
    },
    {
      "id": "s5",
      "section": "Plan",
      "layout": "list-3x",
      "title": "Execution Timeline",
      "type": "timeline",
      "timeline": {
        "name": "Customer success execution path",
        "description": "Major milestones for Evergreen CRM.",
        "events": [
          {
            "when": "Oct",
            "what": "Baseline",
            "description": "Confirm current state, owners, and constraints."
          },
          {
            "when": "May",
            "what": "Pilot",
            "description": "Run a narrow pilot with visible success criteria."
          },
          {
            "when": "Jun",
            "what": "Scale",
            "description": "Expand the approach after risk review."
          },
          {
            "when": "Jul",
            "what": "Embed",
            "description": "Move reporting and routines into steady-state operations."
          }
        ]
      }
    },
    {
      "id": "s6",
      "section": "Close",
      "layout": "list-2x",
      "title": "The Ask",
      "bullets": [
        {
          "text": "Approve the next milestone for recover at-risk renewals with executive sponsorship and value proof.",
          "level": 0
        },
        {
          "text": "Assign an executive sponsor and one accountable owner.",
          "level": 0
        },
        {
          "text": "Review progress in the next operating meeting.",
          "level": 0
        }
      ]
    }
  ],
  "organization": [
    {
      "id": "evergreen-crm",
      "name": "Evergreen CRM",
      "logo": "asset:brand-logo",
      "domain": "evergreen-crm.example",
