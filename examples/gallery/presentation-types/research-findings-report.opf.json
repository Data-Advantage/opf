      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Research report",
            "Program lead",
            "At risk",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "On track",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "Watch",
            "Add weekly office hours"
          ]
        ]
      }
    },
