{
  "$schema": "https://openpresentation.org/schema/opf/v1",
  "name": "Manager Training Deck",
  "description": "Manager Training Deck is a fictional OPF example for training teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "manager-training-deck",
  "language": {
    "id": "english-us",
    "name": "English (United States)",
    "direction": "ltr",
    "fontScheme": "yu-gothic",
    "tags": [
      "presentation-types",
      "training"
    ]
  },
  "audience": [
    "regulators",
    {
      "id": "candidates",
      "attentionBudgetMinutes": 34,
      "technicalFluency": "low",
      "decisionPower": "advisory",
      "recommendedNarratives": [
        "employee-review"
      ],
      "recommendedTones": [
        "inspirational"
      ]
    }
  ],
  "purpose": {
    "id": "report",
    "outcome": "Teach managers a repeatable coaching conversation model",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "inspirational",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": {
    "id": "employee-review",
    "description": "Manager Training Deck uses a compact evidence-to-decision arc for PeopleCraft.",
    "beats": [
      {
        "id": "context",
        "name": "Context",
        "slideType": "text",
        "layoutHint": "text-1x"
      },
      {
        "id": "evidence",
        "name": "Evidence",
        "slideType": "chart",
        "layoutHint": "chart-1x"
      },
      {
        "id": "commitment",
        "name": "Commitment",
        "slideType": "list",
        "layoutHint": "list-3x"
      }
    ]
  },
  "design": {
    "theme": "bold",
    "colorScheme": {
      "id": "cool-horizon",
      "primary": "#6D28D9",
      "secondary": "#0369A1",
      "accent": "#334155",
      "background": "#FFFFFF",
      "text": "#0F172A",
      "custom": {
        "signal": "#E2E8F0",
        "risk": "#F8FAFC"
      }
    },
    "fontScheme": {
      "id": "yu-gothic",
      "heading": {
        "family": "Aptos Display",
        "weight": 700
      },
      "body": {
        "family": "Aptos",
        "weight": 400
      },
      "code": {
        "family": "Consolas",
        "weight": 400
      }
    },
    "dimensions": "letter",
    "background": "light1",
    "titleAlignment": "center",
    "contentAlignment": "right",
    "contentBox": false,
    "contentDirection": "horizontal",
    "chartPrimary": "top",
    "imageFill": "crop",
    "listBullet": "character",
    "logo": {
      "default": "asset:brand-logo",
      "light": "asset:brand-logo-light",
      "icon": "asset:brand-icon",
      "wordmark": "asset:brand-logo"
    },
    "watermark": false,
    "header": {
      "left": {
        "section": true
      },
      "right": {
        "image": "asset:brand-icon"
      }
    },
    "footer": {
      "left": {
        "organization": true
      },
      "center": {
        "text": "Internal planning draft"
      },
      "right": {
        "slideNumber": true
      }
    },
    "slideImage": {
      "src": "asset:cover-bg",
      "position": "left"
    }
  },
  "slides": [
    {
      "id": "s1",
      "section": "Opening",
      "layout": "title-subtitle",
      "tag": "Training",
      "title": "Manager Training Deck",
      "subtitle": "PeopleCraft Training",
      "notes": "Open by naming the decision: Teach managers a repeatable coaching conversation model."
    },
    {
      "id": "s2",
      "section": "Context",
      "layout": "text-2x",
      "title": "Why This Matters",
      "text": [
        "PeopleCraft should focus the next cycle on ",
        {
          "text": "teach managers a repeatable coaching conversation model",
          "bold": true,
          "color": "#6D28D9"
        },
        " while making the operating tradeoffs clear to training stakeholders."
      ]
    },
    {
      "id": "s3",
      "section": "Evidence",
      "layout": "chart-2x",
      "title": "Signal Trend",
      "type": "chart",
      "chart": {
        "type": "100pct-stacked-column-3x",
        "data": {
          "src": "asset:metric-data",
          "sheet": "Summary",
          "range": "A1:C8",
          "columns": [
            "Quarter",
            "Current",
            "Baseline"
          ]
        }
      }
    },
    {
      "id": "s4",
      "section": "Options",
      "layout": "table-1x",
      "title": "Decision Options",
      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Training",
            "Program lead",
            "Watch",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "At risk",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "On track",
            "Add weekly office hours"
          ]
        ]
      }
    },
    {
      "id": "s5",
      "section": "Plan",
      "layout": "text-2x",
      "title": "Execution Timeline",
      "type": "timeline",
      "timeline": {
        "name": "Training execution path",
        "description": "Major milestones for PeopleCraft.",
        "events": [
          {
            "when": "Sep",
            "what": "Baseline",
            "description": "Confirm current state, owners, and constraints."
          },
          {
            "when": "Oct",
            "what": "Pilot",
            "description": "Run a narrow pilot with visible success criteria."
          },
          {
            "when": "May",
            "what": "Scale",
            "description": "Expand the approach after risk review."
          },
          {
            "when": "Jun",
            "what": "Embed",
            "description": "Move reporting and routines into steady-state operations."
          }
        ]
      }
    },
    {
      "id": "s89-regions",
      "section": "Operating model",
      "layout": "number-5x",
      "title": "Operating Model",
      "top:left": {
        "metric": {
          "value": "18%",
          "label": "Primary signal",
          "description": "Teach managers a repeatable coaching conversation model",
          "trend": "flat"
        }
      },
      "top:center+right": {
        "text": [
          "PeopleCraft should focus the next cycle on ",
          {
            "text": "teach managers a repeatable coaching conversation model",
            "bold": true,
            "color": "#6D28D9"
          },
          " while making the operating tradeoffs clear to training stakeholders."
        ]
      },
      "middle+bottom:left": {
        "quote": {
          "text": "The path is workable if we keep the metric simple and the decision owner visible.",
          "attribution": "Training working group",
          "source": "Stakeholder interview"
        }
      },
      "middle+bottom:center+right": {
        "table": {
          "columns": [
            "Workstream",
            "Owner",
            "Status",
            "Decision"
          ],
          "rows": [
            [
              "Training",
              "Program lead",
              "Watch",
              "Continue"
            ],
            [
              "Data and reporting",
              "Analytics",
              "At risk",
              "Tighten metric definitions"
            ],
            [
              "Field adoption",
              "Operations",
              "On track",
              "Add weekly office hours"
            ]
          ]
        }
      },
      "notes": "Use this slide to slow the conversation down around ownership and operating rhythm."
    },
    {
      "id": "s89-blocks",
      "section": "Evidence",
      "layout": "blank",
      "title": "Evidence Pack",
      "blocks": [
        {
          "chart": {
            "type": "bullet-bar-3x",
            "data": {
              "columns": [
                "Quarter",
                "Current",
                "Baseline"
              ],
              "rows": [
                [
                  "Q1",
                  24,
                  21
                ],
                [
                  "Q2",
                  28,
                  23
                ],
                [
                  "Q3",
                  31,
                  25
                ],
                [
                  "Q4",
                  35,
                  27
                ]
              ]
            }
          }
        },
        {
          "quote": {
            "text": "Teams already know where the friction is; the deck makes the sequence of choices explicit.",
            "attribution": "Program sponsor",
            "source": "Planning interview"
          }
        },
        {
          "metric": {
            "value": "11 days",
            "label": "Expected improvement",
            "unit": "%",
            "delta": "+6 pts",
            "trend": "up"
          }
        }
      ]
    },
    {
      "id": "s89-image",
      "section": "Context",
      "layout": "image-1x",
      "title": "Field Context",
      "type": "image",
      "image": {
        "src": "asset:supporting-photo",
        "alt": "Training context photo for PeopleCraft",
        "title": "Training context"
      },
      "notes": "Use the image as context, not decoration."
    },
    {
      "id": "s89-code",
      "section": "Appendix",
      "layout": "code-1x",
      "title": "Decision Rule",
      "code": {
        "source": "const score = urgency * confidence;\nif (score >= threshold) {\n  routeToSponsor(workstream);\n} else {\n  keepInWeeklyReview(workstream);\n}",
        "language": "ts",
        "filename": "manager-training-deck-rule.ts"
      },
      "hidden": false
    },
    {
      "id": "s10",
      "section": "Close",
      "layout": "list-2x",
      "title": "Decision and Follow Through",
      "items": [
        [
          "Commit to ",
          {
            "text": "teach managers a repeatable coaching conversation model",
            "bold": true
          }
        ],
        {
          "text": "Name the sponsor and operating owner.",
          "description": "Keep one person accountable for momentum."
        },
        {
          "text": "Publish the progress rhythm.",
          "description": "Use the same metric definitions every week."
        },
        {
          "text": "Return with proof.",
          "description": "Bring customer, employee, resident, or learner evidence into the next review."
        }
      ]
    }
  ],
