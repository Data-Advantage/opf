{
  "$schema": "https://openpresentation.org/schema/opf/v1",
  "name": "Data Incident Postmortem",
  "description": "Data Incident Postmortem is a fictional OPF example for incident review teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "data-incident-postmortem",
  "language": "english-gb",
  "audience": [
    "executives",
    {
      "id": "sales-team",
      "attentionBudgetMinutes": 31,
      "technicalFluency": "medium",
      "decisionPower": "advisory",
      "recommendedNarratives": [
        "conference-talk"
      ],
      "recommendedTones": [
        "casual"
      ]
    }
  ],
  "purpose": {
    "id": "persuade",
    "outcome": "Explain what happened and what changes prevent recurrence",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "casual",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": "conference-talk",
  "design": {
    "theme": "classic",
    "colorScheme": {
      "id": "bold-red",
      "primary": "#047857",
      "secondary": "#B45309",
      "accent": "#BE123C",
      "background": "#0B1220",
      "text": "#F8FAFC",
      "custom": {
        "signal": "#0369A1",
        "risk": "#6D28D9"
      }
    },
    "fontScheme": {
      "id": "tunga",
      "heading": {
        "family": "Aptos Display",
        "weight": 700
      },
      "body": {
        "family": "Aptos",
        "weight": 400
      },
      "code": {
        "family": "Consolas",
        "weight": 400
      }
    },
    "dimensions": "16:9",
    "background": {
      "type": "gradient",
      "gradient": {
        "angle": 35,
        "stops": [
          {
            "color": "#047857",
            "position": 0
          },
          {
            "color": "#6D28D9",
            "position": 1
          }
        ]
      },
      "opacity": 0.94
    },
    "titleAlignment": "center",
    "contentAlignment": "right",
    "contentBox": false,
    "contentDirection": "vertical",
    "chartPrimary": "none",
    "imageFill": "fit",
    "listBullet": "image",
    "logo": "asset:brand-logo",
    "watermark": {
      "src": "asset:watermark",
      "opacity": 0.06
    },
    "header": false,
    "footer": {
      "left": {
        "organization": true
      },
      "center": {
        "text": "Decision review"
      },
      "right": {
        "slideNumber": true
      }
    },
    "slideImage": {
      "src": "asset:cover-bg",
      "position": "background"
    }
  },
  "slides": [
    {
      "id": "s1",
      "section": "Opening",
      "layout": "title",
      "tag": "Incident review",
      "title": "Data Incident Postmortem",
      "subtitle": "Granite ID Incident review",
      "notes": "Open by naming the decision: Explain what happened and what changes prevent recurrence."
    },
    {
      "id": "s2",
      "section": "Context",
      "layout": "text-2x",
      "title": "Why This Matters",
      "text": [
        "Granite ID should focus the next cycle on ",
        {
          "text": "explain what happened and what changes prevent recurrence",
          "bold": true,
          "color": "#047857"
        },
        " while making the operating tradeoffs clear to incident review stakeholders."
      ]
    },
    {
      "id": "s3",
      "section": "Evidence",
      "layout": "chart-2x",
      "title": "Signal Trend",
      "type": "chart",
      "chart": {
        "type": "100pct-stacked-bar-2x",
        "data": {
          "columns": [
            "Quarter",
            "Current",
            "Baseline"
          ],
          "rows": [
            [
              "Q1",
              12,
              9
            ],
            [
              "Q2",
              16,
              11
            ],
            [
              "Q3",
              19,
              13
            ],
            [
              "Q4",
              23,
              15
            ]
          ]
        }
      }
    },
    {
      "id": "s4",
      "section": "Options",
      "layout": "table-1x",
      "title": "Decision Options",
      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Incident review",
            "Program lead",
            "Watch",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "At risk",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "On track",
            "Add weekly office hours"
          ]
        ]
      }
    },
    {
      "id": "s5",
      "section": "Plan",
      "layout": "list-3x",
      "title": "Execution Timeline",
      "type": "timeline",
      "timeline": {
        "name": "Incident review execution path",
        "description": "Major milestones for Granite ID.",
        "events": [
          {
            "when": "Jun",
            "what": "Baseline",
            "description": "Confirm current state, owners, and constraints."
          },
          {
            "when": "Jul",
            "what": "Pilot",
            "description": "Run a narrow pilot with visible success criteria."
          },
          {
            "when": "Aug",
            "what": "Scale",
            "description": "Expand the approach after risk review."
          },
          {
            "when": "Sep",
            "what": "Embed",
            "description": "Move reporting and routines into steady-state operations."
          }
        ]
      }
    },
    {
      "id": "s6",
      "section": "Close",
      "layout": "list-4x",
      "title": "The Ask",
      "bullets": [
        {
          "text": "Approve the next milestone for explain what happened and what changes prevent recurrence.",
          "level": 0
        },
        {
          "text": "Assign an executive sponsor and one accountable owner.",
          "level": 0
        },
        {
          "text": "Review progress in the next operating meeting.",
          "level": 0
        }
      ]
    }
  ],
  "organization": {
    "id": "granite-id",
    "name": "Granite ID",
    "legalName": "Granite ID, Inc.",
    "logo": "asset:brand-logo",
    "domain": "granite-id.example",
    "email": "hello@granite-id.example",
    "phone": "+15551000085",
    "tagline": "Explain what happened and what changes prevent recurrence",
    "role": "primary",
    "socials": {
      "mastodon": "@granite-id",
      "x": "https://x.example/granite-id"
    }
  },
  "speaker": {
    "id": "speaker",
    "name": "Maya Chen",
    "title": "Program Sponsor",
    "organizationId": "granite-id",
    "bio": "Leads incident review planning for Granite ID.",
    "socials": {
      "mastodon": "@granite-id-speaker"
    }
  },
  "author": "OPF Example Generator",
  "takeaway": "Explain what happened and what changes prevent recurrence",
  "duration": 18,
  "tags": [
    "presentation-types",
    "incident-review",
    "persuade",
    "casual",
    "medium"
  ],
  "assets": {
    "brand-logo": {
      "src": "./assets/granite-id-logo.svg",
      "alt": "Granite ID logo",
      "mediaType": "image/svg+xml"
    },
    "brand-logo-light": {
      "src": "./assets/granite-id-logo-light.svg",
      "alt": "Granite ID light logo",
      "mediaType": "image/svg+xml"
    },
    "brand-icon": {
      "src": "./assets/granite-id-icon.svg",
      "alt": "Granite ID icon",
      "mediaType": "image/svg+xml"
    },
    "cover-bg": {
      "src": "./assets/granite-id-cover-1.jpg",
      "alt": "Incident review background image",
      "mediaType": "image/jpeg"
    },
    "supporting-photo": {
      "src": "./assets/granite-id-field-photo.jpg",
      "alt": "Incident review field context",
      "mediaType": "image/jpeg"
    },
    "demo-video": {
      "src": "./media/granite-id-demo.mp4",
      "title": "Incident review walkthrough",
      "mediaType": "video/mp4"
    },
    "metric-data": {
      "src": "./data/data-incident-postmortem.csv",
      "format": "csv",
      "title": "Data Incident Postmortem data"
    },
    "watermark": {
      "src": "./assets/granite-id-watermark.png",
      "alt": "Granite ID watermark",
      "mediaType": "image/png"
    }
  },
  "extensions": {
    "example": {
      "folder": "presentation-types",
      "density": "medium",
      "scenario": "data-incident-postmortem",
      "generatedBy": "scripts/generate-example-suite.mjs"
    }
  }
