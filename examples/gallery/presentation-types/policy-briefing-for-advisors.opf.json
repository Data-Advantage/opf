  "slides": [
    {
      "id": "s1",
      "section": "Opening",
      "layout": "title",
      "tag": "Policy briefing",
      "title": "Policy Briefing for Advisors",
      "subtitle": "Civic Futures Lab Policy briefing",
      "notes": "Open by naming the decision: Frame tradeoffs for a pending legislative decision."
    },
    {
      "id": "s2",
      "section": "Context",
      "layout": "text-1x",
      "title": "Why This Matters",
      "text": [
        "Civic Futures Lab should focus the next cycle on ",
        {
          "text": "frame tradeoffs for a pending legislative decision",
          "bold": true,
          "color": "#BE123C"
        },
        " while making the operating tradeoffs clear to policy briefing stakeholders."
      ]
    },
    {
      "id": "s3",
      "section": "Evidence",
      "layout": "chart-1x",
      "title": "Signal Trend",
      "type": "chart",
      "chart": {
        "type": "100pct-stacked-column-2x",
        "data": {
          "columns": [
            "Quarter",
            "Current",
            "Baseline"
          ],
          "rows": [
            [
              "Q1",
              14,
              11
            ],
            [
              "Q2",
              18,
              13
            ],
            [
              "Q3",
              21,
              15
            ],
            [
              "Q4",
              25,
              17
            ]
          ]
        }
      }
    },
    {
      "id": "s4",
      "section": "Options",
      "layout": "table-1x",
      "title": "Decision Options",
      "table": {
        "columns": [
          "Workstream",
          "Owner",
          "Status",
          "Decision"
        ],
        "rows": [
          [
            "Policy briefing",
            "Program lead",
            "On track",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "Watch",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "At risk",
            "Add weekly office hours"
          ]
        ]
      }
    },
    {
      "id": "s5",
      "section": "Plan",
      "layout": "list-3x",
      "title": "Execution Timeline",
      "type": "timeline",
      "timeline": {
        "name": "Policy briefing execution path",
        "description": "Major milestones for Civic Futures Lab.",
        "events": [
          {
            "when": "Aug",
            "what": "Baseline",
            "description": "Confirm current state, owners, and constraints."
          },
          {
            "when": "Sep",
            "what": "Pilot",
            "description": "Run a narrow pilot with visible success criteria."
          },
          {
            "when": "Oct",
            "what": "Scale",
            "description": "Expand the approach after risk review."
          },
          {
            "when": "May",
            "what": "Embed",
            "description": "Move reporting and routines into steady-state operations."
          }
        ]
      }
    },
    {
      "id": "s88-regions",
      "section": "Operating model",
      "layout": "number-4x",
      "title": "Operating Model",
      "top:left": {
        "metric": {
          "value": "31%",
          "label": "Primary signal",
          "description": "Frame tradeoffs for a pending legislative decision",
          "trend": "up"
        }
      },
      "top:center+right": {
        "text": [
          "Civic Futures Lab should focus the next cycle on ",
          {
            "text": "frame tradeoffs for a pending legislative decision",
            "bold": true,
            "color": "#BE123C"
          },
          " while making the operating tradeoffs clear to policy briefing stakeholders."
        ]
      },
      "middle+bottom:left": {
        "quote": {
          "text": "The path is workable if we keep the metric simple and the decision owner visible.",
          "attribution": "Policy briefing working group",
          "source": "Stakeholder interview"
        }
      },
      "middle+bottom:center+right": {
        "table": {
          "columns": [
            "Workstream",
            "Owner",
            "Status",
            "Decision"
          ],
          "rows": [
            [
              "Policy briefing",
              "Program lead",
              "On track",
              "Continue"
            ],
            [
              "Data and reporting",
              "Analytics",
              "Watch",
              "Tighten metric definitions"
            ],
            [
              "Field adoption",
              "Operations",
              "At risk",
              "Add weekly office hours"
            ]
          ]
        }
      },
      "notes": "Use this slide to slow the conversation down around ownership and operating rhythm."
    },
    {
      "id": "s88-blocks",
      "section": "Evidence",
      "layout": "text-3x",
      "title": "Evidence Pack",
      "blocks": [
        {
          "chart": {
            "type": "bullet-bar-2x",
            "data": {
              "columns": [
                "Quarter",
                "Current",
                "Baseline"
              ],
              "rows": [
                [
                  "Q1",
                  23,
                  20
                ],
                [
                  "Q2",
                  27,
                  22
                ],
                [
                  "Q3",
                  30,
                  24
                ],
                [
                  "Q4",
                  34,
                  26
                ]
              ]
            }
          }
        },
        {
          "quote": {
            "text": "Teams already know where the friction is; the deck makes the sequence of choices explicit.",
            "attribution": "Program sponsor",
            "source": "Planning interview"
          }
        },
        {
          "metric": {
            "value": "$4.8M",
            "label": "Expected improvement",
            "unit": "days",
            "delta": "-3 days",
            "trend": "down"
          }
        }
      ]
    },
    {
      "id": "s88-video",
      "section": "Context",
      "layout": "media-1x",
      "title": "Demo Moment",
      "type": "video",
      "video": {
        "src": "asset:demo-video",
        "title": "Policy briefing walkthrough",
        "description": "Short clip demonstrating the proposed policy briefing workflow."
      }
    },
    {
      "id": "s88-code",
      "section": "Appendix",
      "layout": "code-1x",
      "title": "Decision Rule",
      "code": {
        "source": "const score = urgency * confidence;\nif (score >= threshold) {\n  routeToSponsor(workstream);\n} else {\n  keepInWeeklyReview(workstream);\n}",
        "language": "ts",
        "filename": "policy-briefing-for-advisors-rule.ts"
      },
      "hidden": true
    },
    {
      "id": "s10",
      "section": "Close",
      "layout": "list-1x",
      "title": "Decision and Follow Through",
      "items": [
        [
          "Commit to ",
          {
            "text": "frame tradeoffs for a pending legislative decision",
            "bold": true
          }
        ],
        {
          "text": "Name the sponsor and operating owner.",
          "description": "Keep one person accountable for momentum."
        },
        {
          "text": "Publish the progress rhythm.",
          "description": "Use the same metric definitions every week."
        },
        {
          "text": "Return with proof.",
          "description": "Bring customer, employee, resident, or learner evidence into the next review."
        }
      ]
    }
