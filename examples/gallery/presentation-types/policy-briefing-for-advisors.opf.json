{
  "$schema": "https://openpresentation.org/schema/opf/v1",
  "name": "Policy Briefing for Advisors",
  "description": "Policy Briefing for Advisors is a fictional OPF example for policy briefing teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "policy-briefing-for-advisors",
  "language": "english-au",
  "audience": [
    "marketing-team",
    {
      "id": "board",
      "attentionBudgetMinutes": 33,
      "technicalFluency": "mixed",
      "decisionPower": "informational",
      "recommendedNarratives": [
        "educate"
      ],
      "recommendedTones": [
        "formal"
      ]
    }
  ],
  "purpose": {
    "id": "plan",
    "outcome": "Frame tradeoffs for a pending legislative decision",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "formal",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": {
    "id": "educate",
    "description": "Policy Briefing for Advisors uses a compact evidence-to-decision arc for Civic Futures Lab.",
    "beats": [
      {
        "id": "context",
        "name": "Context",
        "slideType": "text",
        "layoutHint": "text-1x"
      },
      {
        "id": "evidence",
        "name": "Evidence",
        "slideType": "chart",
        "layoutHint": "chart-1x"
      },
      {
        "id": "commitment",
        "name": "Commitment",
        "slideType": "list",
        "layoutHint": "list-3x"
      }
    ]
  },
  "design": {
    "theme": "minimal",
    "colorScheme": {
      "id": "burnt-orange",
      "primary": "#BE123C",
      "secondary": "#6D28D9",
      "accent": "#0369A1",
      "background": "#0B1220",
      "text": "#F8FAFC",
