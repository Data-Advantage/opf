        "rows": [
          [
            "Academic library",
            "Program lead",
            "On track",
            "Continue"
          ],
          [
            "Data and reporting",
            "Analytics",
            "Watch",
            "Tighten metric definitions"
          ],
          [
            "Field adoption",
            "Operations",
            "At risk",
            "Add weekly office hours"
          ]
