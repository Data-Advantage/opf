{
  "$schema": "https://openpresentation.org/schema/opf/v1",
  "name": "Library Modernization Roadmap",
  "description": "Library Modernization Roadmap is a fictional OPF example for academic library teams. It demonstrates a realistic presentation structure with catalog-backed design and content payloads.",
  "filename": "library-modernization-roadmap",
  "language": "english-gb",
  "audience": [
    "marketing-team",
    {
      "id": "board",
      "attentionBudgetMinutes": 21,
      "technicalFluency": "medium",
      "decisionPower": "informational",
      "recommendedNarratives": [
        "performance-review"
      ],
      "recommendedTones": [
        "casual"
      ]
    }
  ],
  "purpose": {
    "id": "inform",
    "outcome": "Shift the library from stacks-first to research-services-first",
    "successCriteria": [
      "The audience can state the decision in one sentence.",
      "The owner and next checkpoint are explicit."
    ]
  },
  "tone": {
    "id": "casual",
    "voiceCues": [
      "Make the decision visible.",
      "Use concrete operating language."
    ],
    "avoid": [
      "Do not bury the ask.",
      "Do not over-explain obvious context."
    ]
  },
  "narrative": {
    "id": "performance-review",
    "description": "Library Modernization Roadmap uses a compact evidence-to-decision arc for Easton University Library.",
