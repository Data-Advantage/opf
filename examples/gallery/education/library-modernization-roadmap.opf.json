      {
        "id": "context",
        "name": "Context",
        "slideType": "text",
        "layoutHint": "text-1x"
      },
      {
        "id": "evidence",
        "name": "Evidence",
        "slideType": "chart",
        "layoutHint": "chart-1x"
      },
      {
        "id": "commitment",
        "name": "Commitment",
        "slideType": "list",
        "layoutHint": "list-3x"
      }
    ]
  },
